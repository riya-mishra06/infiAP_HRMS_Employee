{
  "permissions": {
    "allow": [
      "Bash(npx expo start)",
      "Bash(npx expo doctor)",
      "Bash(npx expo-doctor)",
      "Bash(npx expo install *)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run type-check)",
      "Bash(npm test)",
      "Bash(npm run test:e2e)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx jest *)",
      "Bash(eas build *)",
      "Bash(eas update *)",
      "Bash(eas submit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(node -e *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-on-save.sh"
          }
        ]
      },
      {
        "matcher": "Bash(npx expo install*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-install.sh"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": true
}
